{
  "family": "sfa-api-staging",
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": ["FARGATE"],
  "executionRoleArn": "arn:aws:iam::395359594148:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::395359594148:role/sfaAppTaskRole",
  "containerDefinitions": [
    {
      "name": "sfa-api",
      "image": "395359594148.dkr.ecr.sa-east-1.amazonaws.com/sfa-api:d8abd87f2c0154c6dc3ccc6aa95d95387bf85099",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "ASPNETCORE_ENVIRONMENT", "value": "Staging" },
        { "name": "DB_AUTH_MODE", "value": "IAM" },
        { "name": "DB_USER", "value": "sfa_app_user" },

        { "name": "Smtp__Host", "value": "smtp.gmail.com" },
        { "name": "Smtp__Port", "value": "587" },
        { "name": "Smtp__FromEmail", "value": "devmatheusoxs@gmail.com" },
        { "name": "Smtp__FromName", "value": "MedlyCare" },
        { "name": "Smtp__EnableSsl", "value": "true" },
        { "name": "Smtp__ResetBaseUrl", "value": "https://staging.medlycare.local/redefinir-senha" }
      ],
      "secrets": [
        { "name": "Jwt__Secret",   "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:Jwt__Secret::" },
        { "name": "Jwt__Issuer",   "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:Jwt__Issuer::" },
        { "name": "Jwt__Audience", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:Jwt__Audience::" },

        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:host::" },
        { "name": "DB_PORT", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:port::" },
        { "name": "DB_NAME", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:dbname::" },

        { "name": "Smtp__User", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:Smtp__User::" },
        { "name": "Smtp__Password", "valueFrom": "arn:aws:secretsmanager:sa-east-1:395359594148:secret:sfa/staging/appsettings:Smtp__Password::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sfa-api-staging",
          "awslogs-region": "sa-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://localhost:8080/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      }
    }
  ]
}
