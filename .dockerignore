# --- Git / VCS ---
.git
.gitignore
.gitattributes

# --- IDE / tooling ---
.vscode/
.idea/
*.user
*.suo
*.sln.docstates

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Docker ---
Dockerfile*
.dockerignore

# --- .NET build artifacts ---
**/bin/
**/obj/
**/out/
**/TestResults/
