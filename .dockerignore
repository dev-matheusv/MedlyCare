# --- Logs / temp ---
**/*.log
logs/
temp/
tmp/

# --- Secrets (garanta que não versiona!) ---
*.secret.json
secrets.json
appsettings.*.local.json

# --- Node/Frontend (caso o repo tenha o Vue) ---
